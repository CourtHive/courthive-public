# courthive-public environment variables
#
# Copy this file to `.env.local` (overrides `.env.development`) and fill in
# the URLs that match your local dev infrastructure.

# competition-factory-server origin. The /public Socket.IO namespace and
# the REST API both live under this host.
VITE_SERVER=http://localhost:8383

# score-relay origin. The /crowd Socket.IO namespace (Phase 3 — sign-in
# to share) lives under this host. Default matches score-relay's default
# RELAY_PORT.
VITE_SCORE_RELAY_URL=http://localhost:8384

# Hash router base. Leave empty for a root-mounted dev server; set to the
# subpath when deploying behind a proxy (e.g. `pub` for /pub/).
BASE_URL=

# Run-time environment label — local | development | production.
ENVIRONMENT=local
